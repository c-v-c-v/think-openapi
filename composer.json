{
    "name": "cvcv/think-openapi",
    "description": "OpenAPI generator and docs UI for ThinkPHP 8 API projects.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.2",
        "topthink/framework": "^8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5"
    },
    "autoload": {
        "psr-4": {
            "Cvcv\\ThinkOpenApi\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Cvcv\\ThinkOpenApi\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "@php vendor/bin/phpunit -c phpunit.xml"
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.2.x-dev"
        },
        "think": {
            "services": [
                "Cvcv\\ThinkOpenApi\\Service"
            ],
            "config": {
                "openapi": "config/openapi.php"
            }
        }
    }
}
